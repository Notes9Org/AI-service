## Biomni Agent (optional - add to .env for Biomni endpoints)
# Main LLM: uses Bedrock (AWS_*) or Anthropic below
# ANTHROPIC_API_KEY=sk-ant-...  # Required for web search tool even when using Bedrock
# NCBI_EMAIL=your@email.com      # Recommended for PubMed/NCBI tools
# SYNAPSE_AUTH_TOKEN=...        # Optional, for Synapse data downloads
# BIOMNI_PATH=/data/biomni
# BIOMNI_DATA_PATH=/path/to/biomni  # alias for BIOMNI_PATH
# Lambda + EFS: set BIOMNI_PATH to EFS mount (e.g. /mnt/biomni/biomni/datalake)
BIOMNI_PATH=/mnt/biomni/biomni/datalake
# BIOMNI_LLM=anthropic.claude-3-5-sonnet-20240620-v1:0
# BIOMNI_TIMEOUT_SECONDS=600
# BIOMNI_TEMPERATURE=0.7
# BIOMNI_SOURCE=Bedrock
# BIOMNI_SKIP_DATALAKE=false
# MCP integration (optional)
# BIOMNI_MCP_CONFIG_PATH=/path/to/mcp_config.yaml

# Chunking Configuration
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Worker Configuration
MAX_RETRIES=3
POLL_INTERVAL=5
BATCH_SIZE=10

# Server Configuration (for main.py)
PORT=8000
CORS_ORIGINS=http://localhost:3000,https://notes9.com

# Logging
LOG_LEVEL=INFO

# LangGraph: strict msgpack deserialization (mitigates checkpoint-store CVE)
# LANGGRAPH_STRICT_MSGPACK=true

RAG_SIMILARITY_THRESHOLD=0.30
RAG_USE_HYBRID=true
