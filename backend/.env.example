# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_JWT_SECRET=your_jwt_secret
DATABASE_URL=postgresql://postgres:password@host:5432/postgres

## AWS Bedrock (LLM)
LLM_PROVIDER=bedrock
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
BEDROCK_CHAT_MODEL_ID=anthropic.claude-3-5-sonnet-20240620-v1:0
BEDROCK_EMBEDDING_MODEL_ID=cohere.embed-v4:0
EMBEDDING_DIMENSIONS=1536

## Biomni Agent (optional - add to .env for Biomni endpoints)
# BIOMNI_PATH=/data/biomni
# BIOMNI_LLM=anthropic.claude-3-5-sonnet-20240620-v1:0
# BIOMNI_TIMEOUT_SECONDS=600
# BIOMNI_TEMPERATURE=0.7
# BIOMNI_SOURCE=Bedrock
# BIOMNI_S3_DATALAKE_BUCKET=biomnidatalake
# BIOMNI_S3_DATALAKE_PREFIX=biomni/datalake
# Result artifacts (optional)
# BIOMNI_S3_BUCKET=biomnidatalake
# BIOMNI_S3_PREFIX=biomni/results
