# Supabase Auth (required for JWT verification)
SUPABASE_JWT_SECRET=your_jwt_secret_here

# Optional - for Supabase client if needed
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# AWS
AWS_REGION=us-east-1

# Bedrock (Biomni uses these)
BEDROCK_CHAT_MODEL_ID=anthropic.claude-3-5-sonnet-20240620-v1:0
BEDROCK_EMBEDDING_MODEL_ID=cohere.embed-v4:0

# Biomni Agent (VPC + EFS)
# Local dev: omit or use biomni/data/biomni (parent of biomni_data/)
# Lambda + EFS: set BIOMNI_PATH to EFS mount (e.g. /mnt/biomni/biomni/datalake)
# BIOMNI_PATH=./data/biomni
BIOMNI_PATH=/mnt/biomni/biomni/datalake
# BIOMNI_LLM=anthropic.claude-3-5-sonnet-20240620-v1:0
# BIOMNI_TIMEOUT_SECONDS=600
# BIOMNI_TEMPERATURE=0.7
# BIOMNI_SOURCE=Bedrock
# BIOMNI_SKIP_DATALAKE=false

# Commercial mode: restrict to commercially-licensed datasets only
BIOMNI_COMMERCIAL_MODE=true

# Anthropic API key (required for web search tool: advanced_web_search_claude)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: S3 for session/result storage
# BIOMNI_S3_BUCKET=your-bucket-name

# MCP integration (optional)
# BIOMNI_MCP_CONFIG_PATH=/path/to/mcp_config.yaml

# CORS
CORS_ORIGINS=http://localhost:3000,https://notes9.com
